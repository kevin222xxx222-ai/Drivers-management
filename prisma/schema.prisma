generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Driver {
  id                String         @id @default(uuid()) @db.Uuid
  driverName        String         @unique @map("driver_name") @db.VarChar(100)
  pinHash           String         @map("pin_hash")
  role              String         @default("DRIVER") @db.VarChar(20)
  isActive          Boolean        @default(true) @map("is_active")
  displayOrder      Int            @default(0) @map("display_order")
  hourlyWage        Int            @default(0) @map("hourly_wage")
  gasSettlementType String         @default("INCLUDED") @map("gas_settlement_type") @db.VarChar(20)
  gasType           String?        @map("gas_type") @db.VarChar(50)
  gasRate           Decimal?       @map("gas_rate") @db.Decimal(10, 2)
  deletedAt         DateTime?      @map("deleted_at")
  deletedByAdminId  String?        @map("deleted_by_admin_id") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  logs              DriverLog[]
  notifications     Notification[]
  statusCorrections DriverStatusCorrection[]
  workTimeCorrections DriverWorkTimeCorrection[]

  @@map("drivers")
}

model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  adminId      String   @unique @map("admin_id") @db.VarChar(100)
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  statusCorrections DriverStatusCorrection[]
  workTimeCorrections DriverWorkTimeCorrection[]

  @@map("admins")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userType         String    @map("user_type") @db.VarChar(20)
  userId           String    @map("user_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash")
  isActive         Boolean   @default(true) @map("is_active")
  loginAt          DateTime  @default(now()) @map("login_at")
  logoutAt         DateTime? @map("logout_at")
  lastAccessAt     DateTime? @map("last_access_at")
  expiresAt        DateTime? @map("expires_at")

  @@map("sessions")
}

model DriverLog {
  id                  String           @id @default(uuid()) @db.Uuid
  businessDate        DateTime         @map("business_date") @db.Date
  datetime            DateTime         @default(now())
  driverId            String           @map("driver_id") @db.Uuid
  driverName          String           @map("driver_name") @db.VarChar(100)
  action              String           @db.VarChar(50)
  status              String           @db.VarChar(50)
  type                String?          @db.VarChar(50)
  castName            String?          @map("cast_name") @db.VarChar(100)
  destination         String?
  scheduledClockOut   DateTime?        @map("scheduled_clock_out")
  oldScheduledClockOut DateTime?        @map("old_scheduled_clock_out")
  newScheduledClockOut DateTime?        @map("new_scheduled_clock_out")
  travelMinutes       Int?             @map("travel_minutes")
  estimatedArrival    DateTime?        @map("estimated_arrival")
  actualArrival       DateTime?        @map("actual_arrival")
  dropoffTime         DateTime?        @map("dropoff_time")
  clockOutTime        DateTime?        @map("clock_out_time")
  roundedClockOutTime DateTime?        @map("rounded_clock_out_time")
  workHours           Decimal?         @map("work_hours") @db.Decimal(5, 2)
  hourlyWage          Int?             @map("hourly_wage")
  wageSubtotal        Int?             @map("wage_subtotal")
  gasSettlementType   String?          @map("gas_settlement_type") @db.VarChar(20)
  gasType             String?          @map("gas_type") @db.VarChar(50)
  gasRate             Decimal?         @map("gas_rate") @db.Decimal(10, 2)
  distance            Decimal?         @db.Decimal(10, 2)
  gasSubtotal         Int?             @map("gas_subtotal")
  totalPayment        Int?             @map("total_payment")
  dailyReport         String?          @map("daily_report")
  waitPlace           String?          @map("wait_place") @db.VarChar(50)
  memo                String?
  latitude            Decimal?         @db.Decimal(10, 7)
  longitude           Decimal?         @db.Decimal(10, 7)
  accuracy            Decimal?         @db.Decimal(10, 2)
  locationCapturedAt  DateTime?        @map("location_captured_at")
  affectsStatus       Boolean          @default(true) @map("affects_status")
  discordSent         Boolean          @default(false) @map("discord_sent")
  discordSentAt       DateTime?        @map("discord_sent_at")
  discordWebhookType  String?          @map("discord_webhook_type") @db.VarChar(50)
  createdByUserType   String?          @map("created_by_user_type") @db.VarChar(20)
  createdByUserId     String?          @map("created_by_user_id") @db.Uuid
  updatedByUserType   String?          @map("updated_by_user_type") @db.VarChar(20)
  updatedByUserId     String?          @map("updated_by_user_id") @db.Uuid
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  driver              Driver           @relation(fields: [driverId], references: [id])
  audits              DriverLogAudit[]
  notifications       Notification[]
  statusCorrections   DriverStatusCorrection[]

  @@index([driverId, businessDate, affectsStatus, datetime])
  @@map("driver_logs")
}

model Notification {
  id           String     @id @default(uuid()) @db.Uuid
  category     String     @default("SYSTEM") @db.VarChar(20)
  type         String     @db.VarChar(50)
  severity     String     @db.VarChar(20)
  title        String     @db.VarChar(200)
  message      String
  driverId     String?    @map("driver_id") @db.Uuid
  relatedLogId String?    @map("related_log_id") @db.Uuid
  isRead       Boolean    @default(false) @map("is_read")
  createdAt    DateTime   @default(now()) @map("created_at")
  readAt       DateTime?  @map("read_at")
  driver       Driver?    @relation(fields: [driverId], references: [id])
  relatedLog   DriverLog? @relation(fields: [relatedLogId], references: [id])

  @@unique([type, relatedLogId])
  @@index([category, isRead, createdAt])
  @@index([isRead, createdAt])
  @@index([type, createdAt])
  @@map("notifications")
}

model DiscordJob {
  id             String    @id @default(cuid())
  notificationId String?   @map("notification_id") @db.Uuid
  eventLogId     String?   @map("event_log_id") @db.Uuid
  webhookType    String    @map("webhook_type") @db.VarChar(20)
  payload        Json
  status         String    @default("PENDING") @db.VarChar(20)
  attemptCount   Int       @default(0) @map("attempt_count")
  maxAttempts    Int       @default(5) @map("max_attempts")
  nextAttemptAt  DateTime  @default(now()) @map("next_attempt_at")
  lockedAt       DateTime? @map("locked_at")
  sentAt         DateTime? @map("sent_at")
  failedAt       DateTime? @map("failed_at")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([notificationId, webhookType])
  @@index([status, nextAttemptAt])
  @@map("discord_jobs")
}

model DriverLogAudit {
  id              String    @id @default(uuid()) @db.Uuid
  driverLogId     String    @map("driver_log_id") @db.Uuid
  beforeJson      Json      @map("before_json")
  afterJson       Json      @map("after_json")
  editedByAdminId String    @map("edited_by_admin_id") @db.Uuid
  editedAt        DateTime  @default(now()) @map("edited_at")
  reason          String?
  driverLog       DriverLog @relation(fields: [driverLogId], references: [id])

  @@index([driverLogId, editedAt])
  @@map("driver_log_audits")
}

model DriverStatusCorrection {
  id              String     @id @default(uuid()) @db.Uuid
  driverId        String     @map("driver_id") @db.Uuid
  adminId         String     @map("admin_id") @db.Uuid
  beforeStatus    String     @map("before_status") @db.VarChar(50)
  afterStatus     String     @map("after_status") @db.VarChar(50)
  reason          String
  relatedLogId    String?    @map("related_log_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")
  driver          Driver     @relation(fields: [driverId], references: [id])
  admin           Admin      @relation(fields: [adminId], references: [id])
  relatedLog      DriverLog? @relation(fields: [relatedLogId], references: [id])

  @@index([driverId, createdAt])
  @@index([adminId, createdAt])
  @@map("driver_status_corrections")
}

model DriverWorkTimeCorrection {
  id                    String   @id @default(uuid()) @db.Uuid
  driverId              String   @map("driver_id") @db.Uuid
  adminId               String   @map("admin_id") @db.Uuid
  correctionType        String   @map("correction_type") @db.VarChar(50)
  businessDateBefore    DateTime? @map("business_date_before") @db.Date
  businessDateAfter     DateTime? @map("business_date_after") @db.Date
  clockInBefore         DateTime? @map("clock_in_before")
  clockInAfter          DateTime? @map("clock_in_after")
  clockOutBefore        DateTime? @map("clock_out_before")
  clockOutAfter         DateTime? @map("clock_out_after")
  workHoursBefore       Decimal? @map("work_hours_before") @db.Decimal(5, 2)
  workHoursAfter        Decimal? @map("work_hours_after") @db.Decimal(5, 2)
  wageSubtotalBefore    Int?     @map("wage_subtotal_before")
  wageSubtotalAfter     Int?     @map("wage_subtotal_after")
  gasSubtotalBefore     Int?     @map("gas_subtotal_before")
  gasSubtotalAfter      Int?     @map("gas_subtotal_after")
  totalPaymentBefore    Int?     @map("total_payment_before")
  totalPaymentAfter     Int?     @map("total_payment_after")
  reason                String
  relatedClockInLogId   String?  @map("related_clock_in_log_id") @db.Uuid
  relatedClockOutLogId  String?  @map("related_clock_out_log_id") @db.Uuid
  relatedAdminLogId     String?  @map("related_admin_log_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")
  driver                Driver   @relation(fields: [driverId], references: [id])
  admin                 Admin    @relation(fields: [adminId], references: [id])

  @@index([driverId, createdAt])
  @@index([adminId, createdAt])
  @@map("driver_work_time_corrections")
}

model ClockOutAlert {
  id                 String   @id @default(uuid()) @db.Uuid
  driverId           String   @map("driver_id") @db.Uuid
  businessDate       DateTime @map("business_date") @db.Date
  scheduledClockOut  DateTime @map("scheduled_clock_out")
  phase              String   @db.VarChar(20)
  notificationId     String?  @map("notification_id") @db.Uuid
  sentAt             DateTime @default(now()) @map("sent_at")

  @@unique([driverId, businessDate, scheduledClockOut, phase])
  @@map("driver_clock_out_alerts")
}
